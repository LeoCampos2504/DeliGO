// DeliGO - Prisma Schema (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CLIENTES
// ============================================
model Cliente {
  id               String   @id @default(cuid())
  nombre           String
  email            String   @unique
  password         String?
  googleId         String?  @unique
  telefono         String   @default("")
  pushSubscription String?
  fechaRegistro    DateTime @default(now())

  // Email verification
  emailVerified     DateTime?
  verificationToken String?   @unique

  // Protección contra clientes maliciosos
  bloqueado              Boolean   @default(false)
  bloqueadoFecha         DateTime?
  ultimoIp               String    @default("")
  dispositivoFingerprint String    @default("")

  direcciones  Direccion[]
  favoritos    Favorito[]
  pedidos      Pedido[]
  resenas      Resena[]
  chatMensajes ChatMensaje[]
  denuncias    Denuncia[]

  @@map("clientes")
}

model Direccion {
  id         String  @id @default(cuid())
  alias      String
  direccion  String
  referencia String  @default("")
  lat        Float?
  lng        Float?
  clienteId  String
  cliente    Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("direcciones")
}

model Favorito {
  id        String  @id @default(cuid())
  clienteId String
  negocioId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  negocio   Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@unique([clienteId, negocioId])
  @@map("favoritos")
}

// ============================================
// NEGOCIOS
// ============================================
model Negocio {
  id         String  @id @default(cuid())
  slug       String  @unique
  nombre     String  @unique
  usuario    String  @unique
  email      String  @unique @default("pending@deligo.app")
  password   String
  rubro      String  @default("restaurante") // restaurante, ropa, otro
  aprobado   Boolean @default(false)
  suspendido Boolean @default(false)

  // Email verification
  emailVerified     DateTime?
  verificationToken String?   @unique

  // Personalización visual
  colorPrincipal    String  @default("#FB8C00")
  mensajeBienvenida String  @default("")
  logoEnCirculo     Boolean @default(false)
  colorCirculoLogo  String  @default("")
  colorFondo        String  @default("")

  // Categorías de productos
  categorias String @default("[]") // JSON array of strings

  // Categorías de agregados e ingredientes
  agregadosCategorias    String @default("[]") // JSON array of strings
  ingredientesCategorias String @default("[]") // JSON array of strings

  // Secciones del catálogo
  seccionesCatalogo String @default("[]") // JSON array of section objects

  // Horarios (JSON: keys "1"-"7" with apertura/cierre/turno2 etc.)
  horarios      String  @default("{}")
  horarioMode   String  @default("experto") // "simple" = toggle manual, "experto" = horarios por día
  abiertoManual Boolean @default(true) // solo aplica cuando horarioMode = "simple"

  // Redes sociales
  whatsapp  String @default("")
  instagram String @default("")
  facebook  String @default("")

  // Imágenes
  logoUrl        String?
  bannerUrl      String?
  fondoImagenUrl String?

  // Delivery
  ofreceDelivery        Boolean @default(false)
  zonaDeliveryActiva    Boolean @default(false)
  zonasDelivery         String  @default("[]") // JSON array of zone objects
  precioDelivery        Float   @default(0)
  precioDeliveryDefault Float   @default(0)
  deliveryMode          String  @default("") // modo de delivery

  // Ubicación del negocio
  lat Float?
  lng Float?

  // Configuración visual/panel
  mostrarVentas             Boolean   @default(false)
  panelMode                 String    @default("")
  promocionado              Boolean   @default(false)
  ordenPromocion            Int       @default(0)
  destacadoHasta            DateTime? // fecha hasta la cual el negocio es destacado
  seguimientoDeliveryActivo Boolean   @default(false)

  // Salón / Mesas
  salonActivo      Boolean @default(false)
  empleadosActivos Boolean @default(false)
  zonasSalon       String  @default("[]") // JSON array of zone names

  // Pago
  aceptaTransferencia Boolean @default(false)
  aliasBancario       String  @default("")

  // Configuración de pedidos
  toleranciaCancelacion Int @default(5) // minutes
  tiempoEntrega         Int @default(30) // minutes

  // Repartidores
  repartidorCodigo String? @unique

  // Access token for employees (single shared link for pedidos + reseñas)
  tokenEmpleados String? @unique // token for /e/[token] — combined employee view

  // Access token for salon (shared link for mesas/orders view)
  tokenSalon String? @unique // token for /s/[token] — salon mesas view

  // Relations (salón)
  mesas     Mesa[]
  empleados Empleado[]
  codigosIncorporacionMozo CodigoIncorporacionMozo[]
  terminalesSalon          TerminalSalon[]
  vinculacionesTerminalSalon VinculacionTerminalSalon[]

  // Plan
  planTipo            String  @default("prueba")
  planVencimiento     String?
  planFechaInicio     String?
  planFechaRenovacion String?

  // Push
  pushSubscription          String?
  // Separate push subscriptions for the shared-display PWAs:
  //  - pushSubscriptionSalon:      /s/[token] salon view (kitchen/tablet)
  //  - pushSubscriptionEmpleados:  /e/[token] empleados panel (pedidos + reseñas)
  // These are intentionally separate from `pushSubscription` (which is the
  // business owner's personal subscription on the /negocio panel) so a
  // single device can subscribe on multiple shared displays without wiping
  // the owner's subscription.
  pushSubscriptionSalon     String?
  pushSubscriptionEmpleados String?

  // Monetización
  deudaTarifa Float  @default(0)
  limiteDeuda Float?

  // Rating cache
  puntuacionPromedio Float @default(0)
  totalResenas       Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  productos            Producto[]
  agregados            Agregado[]
  ingredientes         Ingrediente[]
  pedidos              Pedido[]
  resenas              Resena[]
  favoritos            Favorito[]
  deudaHistorial       DeudaHistorial[]
  repartidores         RepartidorNegocio[]
  secciones            SeccionCatalogo[]
  opcionesCompartidas  OpcionesCompartidas[]
  promociones          Promocion[]
  denuncias            Denuncia[]
  solicitudesDestacado DestacadoSolicitud[]

  @@map("negocios")
}

// ============================================
// SECCIONES CATÁLOGO
// ============================================
model SeccionCatalogo {
  id          String  @id @default(cuid())
  nombre      String
  orientacion String  @default("vertical") // horizontal, vertical
  orden       Int     @default(0)
  color       String  @default("")
  negocioId   String
  negocio     Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  productos SeccionProducto[]

  @@map("secciones_catalogo")
}

model SeccionProducto {
  id         String          @id @default(cuid())
  seccionId  String
  productoId String
  seccion    SeccionCatalogo @relation(fields: [seccionId], references: [id], onDelete: Cascade)
  producto   Producto        @relation(fields: [productoId], references: [id], onDelete: Cascade)
  orden      Int             @default(0)

  @@unique([seccionId, productoId])
  @@map("seccion_productos")
}

// ============================================
// PRODUCTOS
// ============================================
model Producto {
  id            String  @id @default(cuid())
  nombre        String
  precio        Float
  categoria     String  @default("Sin Categoria")
  imagenUrl     String?
  imagenesExtra String  @default("[]") // JSON array of URLs
  negocioId     String
  stock         Boolean @default(true)
  eliminado     Boolean @default(false)

  // Descuentos
  descuentoActivo Boolean @default(false)
  tipoDescuento   String  @default("porcentaje") // porcentaje, monto
  valorDescuento  Float   @default(0)

  // Restaurante
  descripcion            String?
  secciones              String  @default("[]") // JSON: product option sections
  recomendados           String  @default("[]") // JSON array of product IDs
  opcionesCompartidasIds String  @default("[]") // JSON array of shared option IDs

  // Ropa
  talles   String @default("[]") // JSON array
  colores  String @default("[]") // JSON array
  material String @default("")
  genero   String @default("")

  orden     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  negocio      Negocio               @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  agregados    ProductoAgregado[]
  ingredientes ProductoIngrediente[]
  seccionItems SeccionProducto[]
  itemsPedido  PedidoItem[]
  promociones  Promocion[]

  @@map("productos")
}

model ProductoAgregado {
  id         String   @id @default(cuid())
  productoId String
  agregadoId String
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  agregado   Agregado @relation(fields: [agregadoId], references: [id], onDelete: Cascade)

  @@unique([productoId, agregadoId])
  @@map("producto_agregados")
}

model ProductoIngrediente {
  id            String      @id @default(cuid())
  productoId    String
  ingredienteId String
  producto      Producto    @relation(fields: [productoId], references: [id], onDelete: Cascade)
  ingrediente   Ingrediente @relation(fields: [ingredienteId], references: [id], onDelete: Cascade)

  @@unique([productoId, ingredienteId])
  @@map("producto_ingredientes")
}

// ============================================
// AGREGADOS (Add-ons)
// ============================================
model Agregado {
  id        String  @id @default(cuid())
  nombre    String
  precio    Float   @default(0)
  categoria String  @default("")
  imagenUrl String?
  negocioId String
  negocio   Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  productos ProductoAgregado[]

  @@map("agregados")
}

// ============================================
// INGREDIENTES
// ============================================
model Ingrediente {
  id        String  @id @default(cuid())
  nombre    String
  categoria String  @default("")
  imagenUrl String?
  negocioId String
  negocio   Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  productos ProductoIngrediente[]

  @@map("ingredientes")
}

// ============================================
// PEDIDOS (Orders)
// ============================================
model Pedido {
  id              String  @id @default(cuid())
  negocioId       String
  negocioSlug     String
  negocioNombre   String
  clienteId       String?
  clienteNombre   String
  clienteTelefono String  @default("")

  // Totales
  total          Float
  totalProductos Float
  tarifaServicio Float @default(0)
  precioDelivery Float @default(0)

  // Entrega
  metodoEntrega String  @default("retiro") // retiro, domicilio, mesa
  direccion     String?
  referencia    String?
  lat           Float?
  lng           Float?

  // Mesa / Salón
  mesaId         String?
  mesaNumero     Int?
  empleadoId     String?
  empleadoNombre String?

  // Idempotencia de operaciones
  idempotencyKey         String?
  idempotencyFingerprint String?

  // Ubicación negocio al momento del pedido
  negocioLat Float?
  negocioLng Float?

  // Repartidor asignado (aceptación de pedido)
  repartidorId          String? // ID del repartidor que aceptó el pedido
  repartidorNombre      String? // Nombre del repartidor (denormalizado)
  repartidorAceptaFecha DateTime? // Cuándo aceptó el pedido

  // Ubicación repartidor en tiempo real (seguimiento delivery)
  repartidorLat        Float?
  repartidorLng        Float?
  repartidorLastUpdate DateTime?

  // Pago
  metodoPago String  @default("efectivo") // efectivo, transferencia
  notas      String?

  // Estado
  estado                  String    @default("recibido") // recibido, preparando, en_camino, listo_para_retirar, entregado, cancelado
  deudaAcumulada          Boolean   @default(false)
  canceladoPor            String? // cliente, vendedor, sistema
  canceladoMotivo         String?
  canceladoFecha          DateTime?
  clienteConfirmaRecibido Boolean   @default(false)
  clienteConfirmaFecha    DateTime?
  entregadoPorRepartidor  Boolean   @default(false)
  entregadoFecha          DateTime?

  fecha     DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  negocio  Negocio        @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  cliente  Cliente?       @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  items    PedidoItem[]
  mensajes ChatMensaje[]
  resena   Resena?
  eventos  PedidoEvento[]

  @@unique([negocioId, idempotencyKey])
  @@map("pedidos")
}

model PedidoItem {
  id                   String  @id @default(cuid())
  pedidoId             String
  productoId           String?
  nombre               String
  precio               Float
  cantidad             Int     @default(1)
  agregados            String  @default("[]") // JSON: [{id, nombre, precio}]
  secciones            String  @default("{}") // JSON: {sectionName: option}
  seccionesPrecios     String  @default("{}") // JSON: {key: price}
  ingredientes         String  @default("[]") // JSON
  ingredientesQuitados String  @default("[]") // JSON
  talle                String  @default("")
  color                String  @default("")

  pedido   Pedido    @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto Producto? @relation(fields: [productoId], references: [id])

  @@map("pedido_items")
}

// ============================================
// CHAT
// ============================================
model ChatMensaje {
  id            String   @id @default(cuid())
  pedidoId      String
  remitente     String // cliente, vendedor, repartidor
  texto         String   @default("")
  imagenUrl     String?
  archivoUrl    String?
  archivoNombre String?
  archivoTipo   String?
  leido         Boolean  @default(false)
  fecha         DateTime @default(now())

  pedido    Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  cliente   Cliente? @relation(fields: [clienteId], references: [id])
  clienteId String?

  @@map("chat_mensajes")
}

// ============================================
// RESEÑAS
// ============================================
model Resena {
  id               String    @id @default(cuid())
  negocioId        String
  clienteId        String
  clienteNombre    String
  pedidoId         String    @unique
  puntuacion       Int // 1-5
  comentario       String    @default("")
  rapidez          Int?
  calidad          Int?
  precio           Int?
  respuestaNegocio String?
  fechaRespuesta   DateTime?
  fecha            DateTime  @default(now())

  negocio Negocio @relation(fields: [negocioId], references: [id])
  cliente Cliente @relation(fields: [clienteId], references: [id])
  pedido  Pedido  @relation(fields: [pedidoId], references: [id])

  @@map("resenas")
}

// ============================================
// REPARTIDORES
// ============================================
model Repartidor {
  id               String   @id @default(cuid())
  nombre           String
  email            String   @unique
  password         String?
  googleId         String?  @unique
  telefono         String   @default("")
  pushSubscription String?
  activo           Boolean  @default(true)
  eliminado        Boolean  @default(false)
  fechaRegistro    DateTime @default(now())

  // Email verification
  emailVerified     DateTime?
  verificationToken String?   @unique

  negocios RepartidorNegocio[]

  @@map("repartidores")
}

model RepartidorNegocio {
  id              String   @id @default(cuid())
  repartidorId    String
  negocioId       String
  negocioSlug     String
  negocioNombre   String
  negocioLogoUrl  String?
  codigoAcceso    String
  fechaAsociacion DateTime @default(now())

  repartidor Repartidor @relation(fields: [repartidorId], references: [id], onDelete: Cascade)
  negocio    Negocio    @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@unique([repartidorId, negocioId])
  @@map("repartidor_negocios")
}

// ============================================
// SUPERADMIN
// ============================================
model SuperAdmin {
  id               String   @id @default(cuid())
  password         String
  pushSubscription String?
  createdAt        DateTime @default(now())

  @@map("super_admins")
}

// ============================================
// DEUDA HISTORIAL
// ============================================
model DeudaHistorial {
  id            String   @id @default(cuid())
  negocioId     String
  negocioNombre String
  montoAbonado  Float
  deudaAnterior Float
  fechaAbono    DateTime @default(now())
  tipo          String   @default("abono_total")

  negocio Negocio @relation(fields: [negocioId], references: [id])

  @@map("deuda_historial")
}

// ============================================
// SESIONES
// ============================================
model Sesion {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  userType  String // cliente, negocio, repartidor, superadmin
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("sesiones")
}

// ============================================
// PROMOCIONES (cached view of discounted products)
// ============================================
model Promocion {
  id             String    @id @default(cuid())
  productoId     String    @unique
  negocioId      String
  negocioSlug    String
  negocioNombre  String
  precioOriginal Float
  precioPromo    Float
  descuento      String // e.g. "20%" or "$500"
  fechaInicio    DateTime  @default(now())
  fechaFin       DateTime?
  activa         Boolean   @default(true)

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  negocio  Negocio  @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@map("promociones")
}

// ============================================
// MESAS (Salón)
// ============================================
model Mesa {
  id         String    @id @default(cuid())
  numero     Int
  nombre     String    @default("") // "Patio 1", "Barra 3", etc.
  zona       String    @default("") // zone grouping (e.g., "Patio", "Adentro")
  forma      String    @default("") // "redonda", "cuadrada", etc.
  capacidad  Int       @default(4)
  activa     Boolean   @default(true)
  negocioId  String
  negocio    Negocio   @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  empleadoId String? // Mozo asignado a esta mesa
  empleado   Empleado? @relation(fields: [empleadoId], references: [id], onDelete: SetNull)

  @@unique([negocioId, numero])
  @@map("mesas")
}

// ============================================
// EMPLEADOS (Mozos / Personal)
// ============================================
model CuentaOperativa {
  id            String    @id @default(cuid())
  nombre        String
  email         String    @unique
  password      String?
  googleId      String?   @unique
  telefono      String?
  emailVerified DateTime?
  activo        Boolean   @default(true)
  eliminado     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  empleados     Empleado[]
  codigosUsados CodigoIncorporacionMozo[]

  @@index([activo, eliminado])
  @@map("cuentas_operativas")
}

model Empleado {
  id               String  @id @default(cuid())
  nombre           String
  codigo           String // código corto para identificar al mozo
  rol              String  @default("mozo") // mozo, cajero, cocinero, admin
  permisos         String  @default("[]") // JSON array: ["gestion_pedidos", "gestion_productos", "gestion_caja", "gestion_empleados"]
  activo           Boolean @default(true)
  eliminado        Boolean @default(false)
  token            String? // token para notificaciones push
  pushSubscription String? // push subscription JSON for browser notifications
  negocioId        String
  negocio          Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  cuentaOperativaId String?
  cuentaOperativa   CuentaOperativa? @relation(fields: [cuentaOperativaId], references: [id], onDelete: SetNull)
  mesas            Mesa[] // Mesas asignadas a este mozo
  codigosIncorporacionObjetivo CodigoIncorporacionMozo[]

  @@unique([negocioId, codigo])
  @@unique([negocioId, cuentaOperativaId])
  @@index([cuentaOperativaId])
  @@map("empleados")
}

model CodigoIncorporacionMozo {
  id                        String   @id @default(cuid())
  negocioId                 String
  empleadoObjetivoId        String?
  rol                       String   @default("mozo")
  codeHash                  String   @unique
  codePrefix                String   @default("")
  expiresAt                 DateTime
  // Consumo futuro: transaccion atomica solo si usedAt es null,
  // revokedAt es null y expiresAt sigue vigente.
  usedAt                    DateTime?
  usedByCuentaOperativaId   String?
  revokedAt                 DateTime?
  createdAt                 DateTime @default(now())

  negocio                 Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  empleadoObjetivo        Empleado? @relation(fields: [empleadoObjetivoId], references: [id], onDelete: SetNull)
  usedByCuentaOperativa   CuentaOperativa? @relation(fields: [usedByCuentaOperativaId], references: [id], onDelete: SetNull)

  @@index([negocioId, expiresAt])
  @@index([negocioId, revokedAt])
  @@index([empleadoObjetivoId])
  @@index([usedByCuentaOperativaId])
  @@index([rol])
  @@map("codigos_incorporacion_mozo")
}

// Terminal compartida de salón (PC caja, tablet cocina, monitor, celular salón).
// Autorización futura (NO implementada aún):
//   - `scopes` es la fuente de verdad. Scopes previstos:
//       salon.ver, salon.pedidos.ver, salon.pedidos.cambiar_estado,
//       salon.pedidos.marcar_entregado, salon.mesas.liberar,
//       salon.mesas.reasignar, salon.historial.ver, salon.estadisticas.ver
//   - `perfil` es solo una etiqueta/preset para la UI:
//       pantalla | cocina | salon_completo | personalizado
//   - Una terminal NUNCA recibe permisos de administrador completo.
model TerminalSalon {
  id               String    @id @default(cuid())
  negocioId        String
  nombre           String    @default("Terminal de salón") // nombre visible del dispositivo
  estado           String    @default("activo") // estado/etiqueta; la revocación efectiva se hace vía revokedAt
  perfil           String    @default("pantalla") // etiqueta/preset para UI (no autoriza por sí solo)
  scopes           String    @default("[]") // JSON array — fuente de verdad de autorización (deny-by-default)
  pushSubscription String?
  lastUsedAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  negocio       Negocio                    @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  sesiones      SesionTerminalSalon[]
  vinculaciones VinculacionTerminalSalon[]

  @@index([negocioId, estado])
  @@index([negocioId, revokedAt])
  @@index([lastUsedAt])
  @@map("terminales_salon")
}

model VinculacionTerminalSalon {
  id        String   @id @default(cuid())
  negocioId String
  terminalSalonId String? // emparejamiento asociado a una terminal específica (nullable para compatibilidad)
  codeHash  String   @unique
  codePrefix String  @default("")
  expiresAt DateTime
  usedAt    DateTime?
  revokedAt DateTime?
  createdAt DateTime @default(now())

  negocio       Negocio        @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  terminalSalon TerminalSalon? @relation(fields: [terminalSalonId], references: [id], onDelete: Cascade)

  @@index([negocioId, expiresAt])
  @@index([negocioId, revokedAt])
  @@index([usedAt])
  @@index([terminalSalonId])
  @@map("vinculaciones_terminal_salon")
}

model SesionTerminalSalon {
  id              String   @id @default(cuid())
  terminalSalonId String
  tokenHash       String   @unique
  expiresAt       DateTime
  lastUsedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime @default(now())

  terminalSalon TerminalSalon @relation(fields: [terminalSalonId], references: [id], onDelete: Cascade)

  @@index([terminalSalonId, revokedAt])
  @@index([expiresAt])
  @@index([lastUsedAt])
  @@map("sesiones_terminal_salon")
}

// ============================================
// CONFIG PLATAFORMA
// ============================================
model ConfigPlataforma {
  id                   String   @id @default(cuid())
  clave                String   @unique @default("")
  valor                String   @default("")
  promocionadosActivos Boolean  @default(false)
  updatedAt            DateTime @updatedAt

  @@map("config_plataforma")
}

// ============================================
// OPCIONES COMPARTIDAS
// ============================================
model OpcionesCompartidas {
  id          String   @id @default(cuid())
  nombre      String
  opciones    String   @default("[]") // JSON array of options
  obligatorio Boolean  @default(false)
  maximo      Int      @default(0)
  negocioId   String
  negocio     Negocio  @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("opciones_compartidas")
}

// ============================================
// DENUNCIAS (Customer Reports)
// ============================================
model Denuncia {
  id            String   @id @default(cuid())
  clienteId     String
  negocioId     String
  pedidoId      String? // optional: linked order
  negocioNombre String // denormalized for quick display
  clienteNombre String // denormalized
  motivoTipo    String   @default("otro") // "direccion_falsa", "no_retiro", "no_pago", "comportamiento", "otro"
  motivo        String // reason text (preset label or custom)
  fecha         DateTime @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  negocio Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@index([negocioId])
  @@map("denuncias")
}

// ============================================
// CLIENTES BLOQUEADOS (IP/Device tracking)
// ============================================
model ClienteBloqueado {
  id            String   @id @default(cuid())
  ip            String
  fingerprint   String   @default("")
  clienteId     String? // may be null if just IP block
  clienteNombre String   @default("")
  fecha         DateTime @default(now())

  @@index([ip])
  @@index([fingerprint])
  @@map("clientes_bloqueados")
}

// ============================================
// AUDITORÍA DE ACCIONES
// ============================================
model AuditLog {
  id        String   @id @default(cuid())
  userId    String // who
  userType  String // cliente, negocio, repartidor, superadmin, empleado
  accion    String // what: e.g. "producto.creado", "producto.eliminado", "pedido.estado_cambiado", "negocio.suspendido"
  recurso   String // e.g. "producto", "pedido", "empleado"
  recursoId String   @default("") // ID of the affected resource
  detalle   String   @default("{}") // JSON with additional context (before/after values, etc.)
  ip        String   @default("")
  fecha     DateTime @default(now())

  @@index([userId, fecha])
  @@index([recurso, recursoId])
  @@index([accion])
  @@map("audit_logs")
}

// ============================================
// NOTIFICACIONES (In-app + Push)
// ============================================
model Notificacion {
  id        String   @id @default(cuid())
  userId    String // ID del destinatario
  userType  String // cliente, negocio, repartidor, superadmin, empleado
  tipo      String // order_update, new_order, new_delivery, review, chat, review_request, account_update
  titulo    String // notification title
  cuerpo    String // notification body text
  leido     Boolean  @default(false)
  pedidoId  String? // related order ID (for navigation)
  negocioId String? // related business ID
  datos     String   @default("{}") // JSON: additional data for navigation/action
  createdAt DateTime @default(now())

  @@index([userId, userType, leido, createdAt])
  @@index([userId, userType, createdAt])
  @@map("notificaciones")
}

// ============================================
// HISTORIAL DE PEDIDOS (Eventos)
// ============================================
model PedidoEvento {
  id             String   @id @default(cuid())
  pedidoId       String
  estado         String // recibido, preparando, en_camino, listo_para_retirar, entregado, cancelado
  estadoAnterior String   @default("") // previous state
  userId         String? // who triggered the change
  userType       String? // cliente, negocio, repartidor, superadmin, empleado
  nota           String   @default("") // optional note (e.g. cancellation reason)
  fecha          DateTime @default(now())

  pedido Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@index([pedidoId, fecha])
  @@map("pedido_eventos")
}

// ============================================
// SOLICITUDES DESTACADO
// ============================================
model DestacadoSolicitud {
  id        String  @id @default(cuid())
  negocioId String
  negocio   Negocio @relation(fields: [negocioId], references: [id], onDelete: Cascade)

  // Período solicitado
  meses Int @default(0)
  dias  Int @default(0)

  // Precio calculado
  precio Float

  // Estado: pendiente, aprobada, rechazada
  estado String @default("pendiente")

  // Comprobante
  comprobanteUrl String?

  // Nota del admin al rechazar
  notaAdmin String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([estado, createdAt])
  @@index([negocioId])
  @@map("destacado_solicitudes")
}
